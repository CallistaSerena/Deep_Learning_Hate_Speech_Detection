        "\n",
        "  print(\"=\"*50)\n",
        "  print(name)\n",
        "  print(\"=\"*50)\n",
        "\n",
        "  print(\"Accuracy: \", acc)\n",
        "  print(\"Precision: \", precision)\n",
        "  print(\"Recall: \", recall)\n",
        "  print(\"F1-Score: \", f1)\n",
        "\n",
        "  print(classification_report(y_true, y_pred))\n",
        "\n",
        "  cm = confusion_matrix(y_true, y_pred)\n",
        "\n",
        "  plt.figure(figsize = (5, 4))\n",
        "  sns.heatmap(\n",
        "      cm\n",
        "      , annot = True\n",
        "      , fmt = \"d\"\n",
        "      , cmap = \"Blues\"\n",
        "      , xticklabels=[\"Non-HS (0)\", \"HS (1)\"]\n",
        "      , yticklabels=[\"Non-HS (0)\", \"HS (1)\"]\n",
        "  )\n",
        "  plt.title(name)\n",
        "  plt.show()\n",
        "\n",
        "  return {\n",
        "      \"model_name\": name,\n",
        "      \"accuracy\": acc,\n",
        "      \"precision\": precision,\n",
        "      \"recall\": recall,\n",
        "      \"f1_score\": f1,\n",
        "      \"y_true\": y_true,\n",
        "      \"y_pred\": y_pred\n",
